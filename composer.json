{
    "name": "entertainment-tadka/bot",
    "description": "Telegram Bot for Entertainment Tadka with Advanced Features",
    "type": "project",
    "keywords": ["telegram", "bot", "movie", "request", "hinglish"],
    "homepage": "https://github.com/entertainment-tadka/bot",
    "license": "MIT",
    "authors": [
        {
            "name": "Entertainment Tadka",
            "email": "admin@entertainment-tadka.com"
        }
    ],
    "require": {
        "php": ">=8.1.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "ext-session": "*",
        "ext-fileinfo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "files": ["index.php"],
        "classmap": [
            "src/"
        ]
    },
    "scripts": {
        "post-install-cmd": [
            "@set-permissions",
            "@create-directories"
        ],
        "post-update-cmd": [
            "@set-permissions",
            "@create-directories"
        ],
        "set-permissions": [
            "chmod 666 users.json movies.csv error.log requests.json bot_stats.json || true",
            "chmod 666 cache/movie_index.json cache/metrics.json || true"
        ],
        "create-directories": [
            "mkdir -p backups cache logs tmp sessions data",
            "chmod 777 backups cache logs tmp sessions data"
        ],
        "test": "phpunit tests",
        "cs-check": "phpcs --standard=PSR12 index.php",
        "cs-fix": "phpcbf --standard=PSR12 index.php"
    },
    "config": {
        "platform-check": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": false
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}