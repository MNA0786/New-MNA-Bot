# ==================== docker-compose.yml ====================
# Entertainment Tadka Bot v5.0
# Date: 2026-03-05

version: '3.8'

services:
  # Bot Application
  bot:
    build: .
    container_name: entertainment-bot
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    environment:
      - ENVIRONMENT=production
      - BOT_TOKEN=${BOT_TOKEN}
      - BOT_USERNAME=${BOT_USERNAME}
      - BOT_ID=${BOT_ID}
      - ADMIN_IDS=${ADMIN_IDS}
      - API_ID=${API_ID}
      - API_HASH=${API_HASH}
      - PUBLIC_CHANNEL_1_ID=${PUBLIC_CHANNEL_1_ID}
      - PUBLIC_CHANNEL_1_USERNAME=${PUBLIC_CHANNEL_1_USERNAME}
      - PUBLIC_CHANNEL_2_ID=${PUBLIC_CHANNEL_2_ID}
      - PUBLIC_CHANNEL_2_USERNAME=${PUBLIC_CHANNEL_2_USERNAME}
      - PUBLIC_CHANNEL_3_ID=${PUBLIC_CHANNEL_3_ID}
      - PUBLIC_CHANNEL_3_USERNAME=${PUBLIC_CHANNEL_3_USERNAME}
      - PUBLIC_CHANNEL_4_ID=${PUBLIC_CHANNEL_4_ID}
      - PUBLIC_CHANNEL_4_USERNAME=${PUBLIC_CHANNEL_4_USERNAME}
      - PRIVATE_CHANNEL_1_ID=${PRIVATE_CHANNEL_1_ID}
      - PRIVATE_CHANNEL_2_ID=${PRIVATE_CHANNEL_2_ID}
      - REQUEST_GROUP_ID=${REQUEST_GROUP_ID}
      - REQUEST_GROUP_USERNAME=${REQUEST_GROUP_USERNAME}
    volumes:
      - bot_cache:/var/www/html/cache
      - bot_backups:/var/www/html/backups
      - bot_logs:/var/www/html/logs
      - ./php.ini:/usr/local/etc/php/conf.d/custom.ini
    networks:
      - bot_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/New-MNA-Bot.php?test"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # Database (Optional - if using MySQL)
  mysql:
    image: mysql:8.0
    container_name: entertainment-mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD:-rootpassword}
      MYSQL_DATABASE: ${MYSQL_DATABASE:-entertainment_bot}
      MYSQL_USER: ${MYSQL_USER:-botuser}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD:-botpassword}
    volumes:
      - mysql_data:/var/lib/mysql
      - ./mysql-init:/docker-entrypoint-initdb.d
    networks:
      - bot_network
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Redis for caching (Optional)
  redis:
    image: redis:7-alpine
    container_name: entertainment-redis
    restart: unless-stopped
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD:-redispass}
    volumes:
      - redis_data:/data
    networks:
      - bot_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3

  # Nginx as reverse proxy (Optional)
  nginx:
    image: nginx:alpine
    container_name: entertainment-nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf
      - ./ssl:/etc/nginx/ssl
      - bot_cache:/var/www/html/cache
    networks:
      - bot_network
    depends_on:
      - bot
    healthcheck:
      test: ["CMD", "nginx", "-t"]
      interval: 30s
      timeout: 10s
      retries: 3

# ==================== VOLUMES ====================
volumes:
  bot_cache:
    driver: local
  bot_backups:
    driver: local
  bot_logs:
    driver: local
  mysql_data:
    driver: local
  redis_data:
    driver: local

# ==================== NETWORKS ====================
networks:
  bot_network:
    driver: bridge